generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Utilisateurs ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("MEMBER") // ADMIN | MEMBER | READER
  groupId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group        UserGroup?        @relation(fields: [groupId], references: [id])
  documents    Document[]
  activityLogs ActivityLog[]
  versions     DocumentVersion[]
  contributions WikiContribution[]
}

model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

// ─── Journalisation ─────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  entityName String?
  metadata   String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Dossiers ───────────────────────────────────────────────────────────────

model Folder {
  id         String   @id @default(cuid())
  name       String
  color      String?
  parentId   String?
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderTree")
  documents Document[]

  @@index([parentId])
  @@index([isArchived])
}

// ─── Documents ──────────────────────────────────────────────────────────────

model Document {
  id          String    @id @default(cuid())
  title       String
  description String?
  filename    String
  storedName  String
  filePath    String
  fileSize    Int
  mimeType    String
  categoryId  String?
  folderId    String?
  tags        String    @default("[]")
  authorName  String?
  publishedAt DateTime?
  uploadedBy  String

  // Versioning & cycle de vie
  status         String @default("BROUILLON") // BROUILLON | ENRICHISSEMENT | RELECTURE | DIFFUSION | ARCHIVE
  currentVersion String @default("1.0")
  isArchived     Boolean @default(false)

  // Indexation du contenu (texte extrait du fichier / transcription)
  textContent    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploader      User              @relation(fields: [uploadedBy], references: [id])
  category      Category?         @relation(fields: [categoryId], references: [id])
  folder        Folder?           @relation(fields: [folderId], references: [id])
  versions      DocumentVersion[]
  contributions WikiContribution[]

  @@index([categoryId])
  @@index([uploadedBy])
  @@index([folderId])
  @@index([status])
  @@index([isArchived])
}

// ─── Versioning ─────────────────────────────────────────────────────────────

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    String   // "1.0", "1.1", "2.0"
  type       String   // MAJOR | MINOR
  filename   String
  storedName String
  filePath   String
  fileSize   Int
  changelog  String?  // description du changement
  uploadedBy String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploadedBy], references: [id])

  @@index([documentId])
  @@index([createdAt])
}

// ─── Collaboration Wiki ─────────────────────────────────────────────────────

model WikiContribution {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  content    String   // contenu de la contribution (Markdown)
  type       String   @default("NOTE") // NOTE | COMMENTAIRE | ANNOTATION
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([documentId])
  @@index([userId])
}

// ─── Catégories ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?
  icon        String?
  createdAt   DateTime @default(now())

  documents Document[]
}
